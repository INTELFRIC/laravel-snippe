{
    "name": "intelfric-technology/laravel-snippe",
    "description": "A Laravel package for integrating Snippe Tanzania payment gateway — Mobile Money, Cards, and QR payments.",
    "keywords": ["laravel", "snippe", "payment", "tanzania", "mobile-money", "mpesa", "airtel"],
    "homepage": "https://github.com/intelfric-technology/laravel-snippe",
    "license": "MIT",
    "authors": [
        {
            "name": "Intelfric Technology",
            "email": "dev@intelfric.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "ShadrackJm\\Snippe\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ShadrackJm\\Snippe\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ShadrackJm\\Snippe\\SnippeServiceProvider"
            ],
            "aliases": {
                "Snippe": "ShadrackJm\\Snippe\\Facades\\Snippe"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/pest"
    }
}
